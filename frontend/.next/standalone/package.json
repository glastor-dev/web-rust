{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "spellcheck": "cspell \"src/**/*.{tsx,ts}\"",
    "release": "release-it"
  },
  "lint-staged": {
