{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/arquitectura/layout,_N_T_/arquitectura/page,_N_T_/arquitectura"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/arquitectura/__PAGE__",
    "/arquitectura",
    "/_index",
    "/_head"
  ]
}